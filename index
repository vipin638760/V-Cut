      <div class="fg"><label>Branch</label><select id="sf-branch"></select></div>
      <div class="fg"><label>Role</label><select id="sf-role"><option>Stylist</option><option>Senior Stylist</option><option>Manager</option><option>Assistant</option></select></div>
      <div class="fg"><label>Mobile</label><input id="sf-mobile" placeholder="9999999999"></div>
