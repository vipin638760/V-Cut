</div><!-- content -->
</div><!-- app -->
</div><!-- main-app -->

<div class="toast" id="toast"></div>

<script type="module">
import { initializeApp } from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-app.js';
import {
  getFirestore, collection, doc, getDocs, getDoc,
  setDoc, addDoc, deleteDoc, onSnapshot, serverTimestamp, query, orderBy
} from 'https://www.gstatic.com/firebasejs/10.12.2/firebase-firestore.js';

// ── Helpers ──────────────────────────────────────────────────────────────────
const INR = v => '₹' + Math.abs(Math.round(v||0)).toLocaleString('en-IN');
const MASK = '<span class="hidden-val">●●●●●</span>';
const uid = () => 'id' + Date.now() + Math.random().toString(36).slice(2,6);

let db, branches=[], staff=[], entries=[];
let isAdmin = false;
let ADMIN_PASS = '';
let currentExpTab = 'rent';
let unsubscribers = [];

// ── Toast ─────────────────────────────────────────────────────────────────────
function toast(msg, type='info'){
  const t = document.getElementById('toast');
  t.textContent = msg;
  t.style.background = type==='error'?'#a32d2d':type==='success'?'#3b6d11':'#1a2b4c';
  t.classList.add('show');
  setTimeout(()=>t.classList.remove('show'), 2800);
}
window.toast = toast;

// ── Sync status ───────────────────────────────────────────────────────────────
function setSyncStatus(state){
  const dot = document.getElementById('syncDot');
  const lbl = document.getElementById('syncLabel');
  if(!dot) return;
  dot.className = 'sync-dot' + (state==='offline'?' offline':state==='syncing'?' syncing':'');
  lbl.textContent = state==='online'?'Live':state==='syncing'?'Saving...':'Offline';
}

// ── Firebase Config ───────────────────────────────────────────────────────────
function getStoredConfig(){
  try{ return JSON.parse(localStorage.getItem('vcut_fb_config')||'null'); }
  catch(e){ return null; }
}

function saveConfig(){
  const raw = document.getElementById('fbConfigInput').value.trim();
  const pass = document.getElementById('adminPassInput').value.trim();
  const errEl = document.getElementById('cfgErr');
  let cfg;
  try{
    // allow both object literal and JSON
    cfg = JSON.parse(raw.replace(/(['"])?([a-zA-Z0-9_]+)(['"])?:/g, '"$2":').replace(/'/g,'"'));
    if(!cfg.apiKey || !cfg.projectId) throw new Error('missing fields');
  } catch(e){
    errEl.classList.add('show');
    return;
  }
  if(!pass){ alert('Please set an admin password.'); return; }
  errEl.classList.remove('show');
  localStorage.setItem('vcut_fb_config', JSON.stringify(cfg));
  localStorage.setItem('vcut_admin_pass', pass);
  ADMIN_PASS = pass;
  launchApp(cfg);
}
window.saveConfig = saveConfig;

function reconfigFirebase(){
  localStorage.removeItem('vcut_fb_config');
  location.reload();
}
window.reconfigFirebase = reconfigFirebase;

// ── Boot ──────────────────────────────────────────────────────────────────────
async function boot(){
  ADMIN_PASS = localStorage.getItem('vcut_admin_pass') || 'vcut@2026';
  const cfg = getStoredConfig();
  if(!cfg){
    document.getElementById('setup-screen').style.display = 'block';
    return;
  }
  launchApp(cfg);
}

async function launchApp(cfg){
  document.getElementById('setup-screen').style.display = 'none';
  document.getElementById('main-app').style.display = 'block';
  setSyncStatus('syncing');
  try{
    const app = initializeApp(cfg);
    db = getFirestore(app);
    await seedDefaultData();
    subscribeAll();
  } catch(e){
    setSyncStatus('offline');
    toast('Firebase connection failed: ' + e.message, 'error');
    console.error(e);
  }
}

