        <div class="fg"><label>Salary Budget (₹)</label><input id="set-sal" type="number"></div>
        <div class="fg"><label>WiFi (₹)</label><input id="set-wifi" type="number"></div>
        <div class="fg"><label>Shop Elec (₹)</label><input id="set-selec" type="number"></div>
        <div class="fg"><label>Room Elec (₹)</label><input id="set-relec" type="number"></div>
        <div class="fg"><label>Location</label><input id="set-loc" placeholder="Bangalore"></div>
      </div>
      <div class="btn-row">
        <button class="btn btn-p" onclick="saveBranch()">Save Branch</button>
