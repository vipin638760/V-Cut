function renderDashboard(){
  const totalInc = branches.reduce((s,b)=>s+bIncome(b.id),0);
  const totalExp = branches.reduce((s,b)=>s+bExpenses(b.id),0);
  document.getElementById('dash-kpis').innerHTML = [
    {l:'Total Income',v:INR(totalInc),s:'This month',c:'green'},
    {l:'Total Expenses',v:M(totalExp),s:'All branches',c:'red'},
    {l:'Net P&L',v:isAdmin?(totalInc-totalExp<0?'('+INR(totalInc-totalExp)+')':INR(totalInc-totalExp)):MASK,s:totalInc-totalExp<0?'Loss':'Profit',c:totalInc-totalExp<0?'red':'green'},
    {l:'Branches',v:branches.length,s:'Active locations',c:'blue'},
    {l:'Staff',v:staff.length,s:'Total members',c:'blue'},
    {l:'Entries',v:entries.length,s:'Daily records in Firebase',c:'orange'},
  ].map(k=>`<div class="kpi"><div class="kpi-l">${k.l}</div><div class="kpi-v ${k.c}">${k.v}</div><div class="kpi-s">${k.s}</div></div>`).join('');

  const sorted = [...branches].sort((a,b)=>bIncome(b.id)-bIncome(a.id));
  document.getElementById('dash-table').innerHTML = `<thead><tr><th>Branch</th><th class="num">Income</th><th class="num">Expenses</th><th class="num">Net P&L</th><th>Status</th></tr></thead><tbody>
  ${sorted.map(b=>{const i=bIncome(b.id),e=bExpenses(b.id),n=i-e;return `<tr><td style="font-weight:500">${b.name}</td><td class="num">${INR(i)}</td><td class="num">${M(e)}</td><td class="num">${isAdmin?(n<0?'('+INR(n)+')':INR(n)):MASK}</td><td><span class="pill ${n>=0?'pg':'pr'}">${n>=0?'Profit':'Loss'}</span></td></tr>`;}).join('')}
  <tr class="tf"><td>TOTAL</td><td class="num">${INR(totalInc)}</td><td class="num">${M(totalExp)}</td><td class="num red">${isAdmin?'('+INR(totalExp-totalInc)+')':MASK}</td><td></td></tr></tbody>`;

  const totSal = branches.reduce((s,b)=>s+bStaff(b.id).reduce((ss,st)=>ss+(st.salary||0),0),0);
  const totRent = branches.reduce((s,b)=>s+(b.shop_rent||0)+(b.room_rent||0),0);
  const totElec = branches.reduce((s,b)=>s+(b.shop_elec||0)+(b.room_elec||0),0);
  const totWifi = branches.reduce((s,b)=>s+(b.wifi||0),0);
  const totInc2 = entries.reduce((s,e)=>s+(e.staff_billing||[]).reduce((ss,sb)=>ss+(sb.incentive||0),0),0);
  const totCash = entries.reduce((s,e)=>s+(e.tips||0)+(e.others||0)+(e.material||0)+(e.petrol||0),0);
  const totExp = totSal+totRent+totElec+totInc2+totWifi+totCash;
  document.getElementById('dash-exp').innerHTML=`<thead><tr><th>Category</th><th class="num">Amount</th><th class="num">%</th></tr></thead><tbody>
  ${[['Salary',totSal,true],['Rent',totRent,true],['Electricity',totElec,false],['Incentives',totInc2,false],['WiFi',totWifi,false],['Cash/Misc',totCash,false]].map(([cat,amt,adm])=>`<tr><td>${cat}</td><td class="num">${adm?M(amt):INR(amt)}</td><td class="num">${totExp>0&&(isAdmin||!adm)?(amt/totExp*100).toFixed(1)+'%':adm?MASK:'0%'}</td></tr>`).join('')}</tbody>`;
}

