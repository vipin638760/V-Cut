<!-- SETTINGS -->
<div class="page" id="page-settings">
  <div id="settings-admin-gate" style="display:none">
    <div class="form-panel">
      <div class="form-title">Add / Edit Branch</div>
      <div class="form-grid">
        <div class="fg"><label>Branch Name</label><input id="set-name" placeholder="V-CUT NEW BRANCH"></div>
        <div class="fg"><label>Type</label><select id="set-type"><option value="mens">Men's Salon</option><option value="unisex">Unisex</option></select></div>
