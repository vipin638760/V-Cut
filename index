async function saveEntry(){
  const bid = document.getElementById('e-branch').value;
  const date = document.getElementById('e-date').value;
  if(!bid||!date){ toast('Select branch and date','error'); return; }
  setSyncStatus('syncing');
  const brStaff = bStaff(bid);
  const staff_billing = brStaff.map(s=>({
    staff_id:s.id, name:s.name,
    billing:parseFloat(document.getElementById('sb-b-'+s.id)?.value||0),
    incentive:parseFloat(document.getElementById('sb-i-'+s.id)?.value||0)
  })).filter(x=>x.billing>0||x.incentive>0);

  const entry = {
    branch_id:bid, date,
    online:parseFloat(document.getElementById('ei-online')?.value||0),
    cash:parseFloat(document.getElementById('ei-cash')?.value||0),
    material:parseFloat(document.getElementById('ei-material')?.value||0),
    tips:parseFloat(document.getElementById('ei-tips')?.value||0),
    others:parseFloat(document.getElementById('ei-others')?.value||0),
    petrol:parseFloat(document.getElementById('ei-petrol')?.value||0),
    notes:document.getElementById('ei-notes')?.value||'',
    staff_billing, saved_at: new Date().toISOString()
  };

  try{
    // check if entry exists for same branch+date
    const existing = entries.find(e=>e.branch_id===bid&&e.date===date);
    if(existing){
      await setDoc(doc(db,'entries',existing.id), entry);
      toast('Entry updated in Firebase!','success');
    } else {
      await addDoc(collection(db,'entries'), entry);
      toast('Entry saved to Firebase!','success');
    }
    document.getElementById('entry-status').textContent = 'Saved at '+new Date().toLocaleTimeString();
  } catch(e){
    setSyncStatus('offline');
    toast('Save failed: '+e.message,'error');
  }
}
window.saveEntry = saveEntry;

