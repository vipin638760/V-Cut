<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>V-CUT Group — Live Dashboard</title>
<style>
*{box-sizing:border-box;margin:0;padding:0}
body{font-family:system-ui,sans-serif;background:#f0f2f5;color:#111;min-height:100vh;font-size:13px}
.app{display:flex;flex-direction:column;min-height:100vh}
.topbar{background:#1a2b4c;color:#fff;padding:0 20px;display:flex;align-items:center;gap:12px;height:52px;flex-shrink:0}
.topbar h1{font-size:15px;font-weight:500;letter-spacing:.3px}
.tb-badge{background:#c9a83c;color:#1a2b4c;font-size:10px;font-weight:600;padding:2px 7px;border-radius:4px}
.tb-right{display:flex;align-items:center;gap:8px;margin-left:auto}
.sync-dot{width:7px;height:7px;border-radius:50%;background:#4caf50;animation:pulse 2s infinite;flex-shrink:0}
.sync-dot.offline{background:#e24b4a;animation:none}
.sync-dot.syncing{background:#c9a83c}
@keyframes pulse{0%,100%{opacity:1}50%{opacity:.4}}
.sync-label{font-size:10px;opacity:.7}
.admin-pill{font-size:10px;font-weight:600;padding:2px 8px;border-radius:4px;cursor:pointer;user-select:none;border:none}
.admin-pill.off{background:#374a6e;color:#a0b0cc}
.admin-pill.on{background:#c9a83c;color:#1a2b4c}

.nav{background:#fff;border-bottom:.5px solid #e0e0e0;display:flex;overflow-x:auto;flex-shrink:0;padding:0 8px}
.nav::-webkit-scrollbar{height:2px}.nav::-webkit-scrollbar-thumb{background:#c9a83c}
.nb{padding:11px 14px;font-size:12px;color:#666;cursor:pointer;white-space:nowrap;border:none;background:none;border-bottom:2px solid transparent;transition:all .15s}
.nb.active{color:#1a2b4c;border-bottom-color:#c9a83c;font-weight:500}
.nb:hover:not(.active){color:#111}

.content{flex:1;padding:16px;max-width:1400px;width:100%;margin:0 auto}
.page{display:none}.page.active{display:block}

/* Setup screen */
.setup-wrap{max-width:560px;margin:40px auto}
.setup-card{background:#fff;border:.5px solid #e0e0e0;border-radius:14px;padding:28px}
.setup-card h2{font-size:17px;font-weight:500;margin-bottom:6px;color:#1a2b4c}
.setup-card p{font-size:12px;color:#666;margin-bottom:20px;line-height:1.6}
.setup-step{background:#f0f4fa;border-radius:8px;padding:12px 14px;margin-bottom:10px;font-size:12px;line-height:1.7;border-left:3px solid #1a2b4c}
.setup-step strong{color:#1a2b4c}
.setup-step code{background:#dde6f5;padding:1px 5px;border-radius:3px;font-family:monospace;font-size:11px}
.cfg-input{width:100%;padding:9px 12px;border:.5px solid #e0e0e0;border-radius:8px;font-size:12px;font-family:monospace;margin-top:6px;color:#111;background:#fff}
.cfg-input:focus{outline:none;border-color:#1a2b4c}
.setup-err{font-size:11px;color:#a32d2d;margin-top:6px;display:none}
.setup-err.show{display:block}

.kpi-grid{display:grid;grid-template-columns:repeat(auto-fit,minmax(148px,1fr));gap:8px;margin-bottom:16px}
.kpi{background:#fff;border:.5px solid #e0e0e0;border-radius:10px;padding:12px 14px}
.kpi-l{font-size:10px;color:#666;text-transform:uppercase;letter-spacing:.4px;margin-bottom:4px}
.kpi-v{font-size:20px;font-weight:500;line-height:1}
.kpi-s{font-size:10px;color:#666;margin-top:3px}
.red{color:#a32d2d}.green{color:#3b6d11}.orange{color:#854f0b}.blue{color:#185fa5}

.st{font-size:13px;font-weight:500;margin-bottom:10px;color:#111}
.card{background:#fff;border:.5px solid #e0e0e0;border-radius:10px;overflow:hidden;margin-bottom:12px}
table{width:100%;border-collapse:collapse;font-size:12px}
th{background:#f0f4fa;color:#1a2b4c;font-weight:500;font-size:11px;padding:7px 11px;text-align:left;border-bottom:1px solid #e0e8f5;white-space:nowrap}
td{padding:7px 11px;border-bottom:.5px solid #e0e0e0;color:#111}
tr:last-child td{border-bottom:none}
tr:hover td{background:#fafafa}
.tf td{background:#f0f4fa;font-weight:500}
.num{text-align:right;font-variant-numeric:tabular-nums}
.pill{display:inline-block;padding:2px 7px;border-radius:4px;font-size:10px;font-weight:500}
.pr{background:#fcebeb;color:#a32d2d}.pg{background:#eaf3de;color:#3b6d11}
.pa{background:#faeeda;color:#854f0b}.pb{background:#e6f1fb;color:#185fa5}
.two-col{display:grid;grid-template-columns:1fr 1fr;gap:12px}
@media(max-width:640px){.two-col{grid-template-columns:1fr}}
.section-divider{height:.5px;background:#e0e0e0;margin:14px 0}

.branch-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(260px,1fr));gap:10px;margin-bottom:16px}
.bcard{background:#fff;border:.5px solid #e0e0e0;border-radius:10px;overflow:hidden;cursor:pointer;transition:box-shadow .15s}
.bcard:hover{box-shadow:0 2px 10px rgba(26,43,76,.1)}
.bcard-head{background:#1a2b4c;color:#fff;padding:9px 13px;display:flex;justify-content:space-between;align-items:center;font-size:12px;font-weight:500}
.bcard-body{padding:10px 13px}
.br{display:flex;justify-content:space-between;padding:3px 0;border-bottom:.5px solid #e0e0e0;font-size:11px}
.br:last-child{border-bottom:none}
.br .bl{color:#666}

.detail-hdr{display:flex;align-items:center;gap:10px;margin-bottom:14px;flex-wrap:wrap}
.back-btn{background:none;border:.5px solid #e0e0e0;border-radius:6px;padding:5px 11px;font-size:11px;cursor:pointer;color:#666}
.back-btn:hover{background:#f5f5f5}

.form-panel{background:#fff;border:.5px solid #e0e0e0;border-radius:8px;padding:14px;margin-bottom:12px}
.form-title{font-size:12px;font-weight:500;margin-bottom:10px;padding-bottom:7px;border-bottom:.5px solid #e0e0e0}
.form-grid{display:grid;grid-template-columns:repeat(auto-fill,minmax(155px,1fr));gap:8px;margin-bottom:10px}
.fg{display:flex;flex-direction:column;gap:3px}
.fg label{font-size:10px;color:#666;font-weight:500}
.fg input,.fg select{padding:7px 9px;border:.5px solid #e0e0e0;border-radius:6px;font-size:12px;background:#fff;color:#111;width:100%}
.fg input:focus,.fg select:focus{outline:none;border-color:#1a2b4c}
.btn{padding:6px 13px;border-radius:6px;font-size:12px;cursor:pointer;font-weight:500;border:none}
.btn-p{background:#1a2b4c;color:#fff}.btn-p:hover{background:#243d6a}
.btn-s{background:none;border:.5px solid #e0e0e0;color:#666}.btn-s:hover{background:#f5f5f5}
.btn-d{background:#fcebeb;color:#a32d2d;border:.5px solid #f7c1c1}
.btn-sm{padding:3px 8px;font-size:11px}
.btn-row{display:flex;gap:7px;align-items:center;flex-wrap:wrap}

.tab2{display:flex;gap:6px;margin-bottom:12px;flex-wrap:wrap}
.t2b{padding:5px 12px;font-size:11px;border:.5px solid #e0e0e0;border-radius:6px;cursor:pointer;background:none;color:#666}
.t2b.active{background:#1a2b4c;color:#fff;border-color:#1a2b4c}

.toast{position:fixed;bottom:20px;right:20px;background:#1a2b4c;color:#fff;padding:9px 14px;border-radius:8px;font-size:12px;z-index:9999;opacity:0;transition:opacity .3s;pointer-events:none;max-width:280px}
.toast.show{opacity:1}

/* Admin overlay */
.overlay{position:fixed;inset:0;background:rgba(10,20,40,.7);z-index:1000;display:flex;align-items:center;justify-content:center}
.overlay.hidden{display:none}
.overlay-box{background:#fff;border-radius:14px;padding:28px;width:300px}
.overlay-box h3{font-size:15px;font-weight:500;margin-bottom:4px;color:#1a2b4c}
.overlay-box p{font-size:11px;color:#666;margin-bottom:16px}
.overlay-box input{width:100%;padding:9px 11px;border:.5px solid #e0e0e0;border-radius:7px;font-size:13px;margin-bottom:10px;letter-spacing:2px}
.overlay-box input:focus{outline:none;border-color:#1a2b4c}
.overlay-err{font-size:11px;color:#a32d2d;margin-bottom:8px;display:none}
.overlay-err.show{display:block}

/* Loading spinner */
.loading{display:flex;align-items:center;gap:10px;padding:30px;color:#666;font-size:13px;justify-content:center}
.spinner{width:20px;height:20px;border:2px solid #e0e0e0;border-top-color:#1a2b4c;border-radius:50%;animation:spin .7s linear infinite;flex-shrink:0}
@keyframes spin{to{transform:rotate(360deg)}}
.hidden-val{filter:blur(4px);user-select:none;pointer-events:none;display:inline-block}
</style>
</head>
<body>

<!-- Admin login overlay -->
<div class="overlay hidden" id="adminOverlay">
  <div class="overlay-box">
    <h3>Admin Login</h3>
    <p>Enter admin password to view salary, rent and financial details.</p>
    <input type="password" id="adminPw" placeholder="Password..." onkeydown="if(event.key==='Enter')checkAdmin()">
    <div class="overlay-err" id="adminErr">Wrong password. Try again.</div>
    <div class="btn-row">
      <button class="btn btn-p" style="flex:1" onclick="checkAdmin()">Login</button>
      <button class="btn btn-s" onclick="closeAdmin()">Cancel</button>
    </div>
  </div>
</div>

<!-- Firebase Setup Screen -->
<div id="setup-screen" style="display:none">
  <div style="background:#1a2b4c;color:#fff;padding:0 20px;height:52px;display:flex;align-items:center;gap:10px">
    <span style="font-size:15px;font-weight:500">V-CUT GROUP</span>
    <span style="background:#c9a83c;color:#1a2b4c;font-size:10px;font-weight:600;padding:2px 7px;border-radius:4px">SETUP</span>
  </div>
  <div class="setup-wrap">
    <div class="setup-card">
      <h2>Connect to Firebase</h2>
      <p>Follow these steps once to connect your dashboard to Firebase. After setup, all data syncs across all devices and branches in real-time.</p>

      <div class="setup-step">
        <strong>Step 1 — Create Firebase project</strong><br>
        Go to <strong>console.firebase.google.com</strong> → Click <strong>"Add project"</strong> → Name it <code>vcut-dashboard</code> → Disable Google Analytics → Click <strong>"Create project"</strong>
      </div>

      <div class="setup-step">
        <strong>Step 2 — Enable Firestore Database</strong><br>
        In your project → Left sidebar → <strong>"Firestore Database"</strong> → <strong>"Create database"</strong> → Choose <strong>"Start in test mode"</strong> → Pick region <code>asia-south1</code> (Mumbai) → Done
      </div>

      <div class="setup-step">
        <strong>Step 3 — Get your config</strong><br>
        Left sidebar → <strong>Project Settings</strong> (gear icon) → Scroll to <strong>"Your apps"</strong> → Click <strong>"Web" (&lt;/&gt;)</strong> → Register app as <code>vcut-web</code> → Copy the <code>firebaseConfig</code> object shown
      </div>

      <div class="setup-step">
        <strong>Step 4 — Paste config below</strong><br>
        Paste the entire config object from Firebase here:
        <textarea class="cfg-input" id="fbConfigInput" rows="8" placeholder='{
  "apiKey": "AIza...",
  "authDomain": "vcut-dashboard.firebaseapp.com",
  "projectId": "vcut-dashboard",
  "storageBucket": "vcut-dashboard.appspot.com",
  "messagingSenderId": "123456789",
  "appId": "1:123456789:web:abc123"
}'></textarea>
        <div class="setup-err" id="cfgErr">Invalid config — make sure you paste the full JSON object from Firebase.</div>
      </div>

      <div class="setup-step" style="border-left-color:#c9a83c">
        <strong>Admin Password</strong><br>
        Set your admin password (for salary/rent access):
        <input type="password" class="cfg-input" id="adminPassInput" placeholder="Enter admin password e.g. VCut@2026" style="letter-spacing:1px">
      </div>

      <button class="btn btn-p" style="width:100%;margin-top:14px;padding:10px" onclick="saveConfig()">Connect & Launch Dashboard</button>
    </div>
  </div>
</div>

<!-- Main App -->
<div id="main-app" style="display:none">
<div class="app">
<div class="topbar">
  <h1>V-CUT GROUP</h1>
  <span class="tb-badge">FIREBASE</span>
  <span style="font-size:10px;opacity:.6" id="syncTime"></span>
  <div class="tb-right">
    <span class="sync-dot" id="syncDot"></span>
    <span class="sync-label" id="syncLabel">Connecting...</span>
    <button class="admin-pill off" id="adminPill" onclick="handleAdminClick()">ADMIN</button>
  </div>
</div>
<div class="nav">
  <button class="nb active" onclick="showPage('dashboard',this)">Dashboard</button>
  <button class="nb" onclick="showPage('branches',this)">Branches</button>
  <button class="nb" onclick="showPage('entry',this)">Data Entry</button>
  <button class="nb" onclick="showPage('staff',this)">Staff</button>
  <button class="nb" onclick="showPage('expenses',this)">Expenses</button>
  <button class="nb" onclick="showPage('pl',this)">P&L Report</button>
  <button class="nb" onclick="showPage('settings',this)">Settings</button>
</div>
<div class="content">

<!-- DASHBOARD -->
<div class="page active" id="page-dashboard">
  <div class="kpi-grid" id="dash-kpis"></div>
  <div class="two-col">
    <div><div class="st">Branch performance</div><div class="card"><table id="dash-table"></table></div></div>
    <div><div class="st">Expense breakdown</div><div class="card"><table id="dash-exp"></table></div></div>
  </div>
</div>

<!-- BRANCHES -->
<div class="page" id="page-branches">
  <div id="branch-list-view">
    <div class="tab2">
      <button class="t2b active" onclick="filterB('all',this)">All</button>
      <button class="t2b" onclick="filterB('mens',this)">Men's</button>
      <button class="t2b" onclick="filterB('unisex',this)">Unisex</button>
    </div>
    <div class="branch-grid" id="branch-grid"></div>
  </div>
  <div id="branch-detail-view" style="display:none"></div>
</div>

<!-- DATA ENTRY -->
<div class="page" id="page-entry">
  <div class="form-panel">
    <div class="form-title">Daily Sales Entry</div>
    <div class="form-grid">
      <div class="fg"><label>Branch</label><select id="e-branch" onchange="loadEntryForm()"><option value="">Select...</option></select></div>
      <div class="fg"><label>Date</label><input type="date" id="e-date"></div>
    </div>
    <div id="entry-body" style="display:none">
      <div class="form-grid" id="e-income"></div>
      <div class="section-divider"></div>
      <div class="st" style="margin-bottom:8px;font-size:12px">Staff Billing</div>
      <div id="e-staff"></div>
      <div class="section-divider"></div>
      <div class="form-grid" id="e-expenses"></div>
      <div class="btn-row">
        <button class="btn btn-p" onclick="saveEntry()">Save to Firebase</button>
        <button class="btn btn-s" onclick="clearEntry()">Clear</button>
