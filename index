    <p style="font-size:12px;color:#666">Login as Admin to add or edit branches.</p>
  </div>
  <div class="st">All Branches</div>
  <div class="card"><table id="settings-table"></table></div>
  <div class="section-divider"></div>
  <div class="btn-row">
    <button class="btn btn-s" onclick="reconfigFirebase()">Change Firebase Config</button>
