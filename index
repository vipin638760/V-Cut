function M(val){ return isAdmin ? INR(val) : MASK; }
function MP(val){ return isAdmin ? val : '●●●'; }

// ── Computed helpers ──────────────────────────────────────────────────────────
function bIncome(bid){ return entries.filter(e=>e.branch_id===bid).reduce((s,e)=>s+(e.online||0)+(e.cash||0),0); }
function bStaff(bid){ return staff.filter(s=>s.branch_id===bid); }
function bEntries(bid){ return entries.filter(e=>e.branch_id===bid); }
function bExpenses(bid){
  const b = branches.find(x=>x.id===bid); if(!b) return 0;
  const sal = bStaff(bid).reduce((s,st)=>s+(st.salary||0),0);
  const inc = entries.filter(e=>e.branch_id===bid).reduce((s,e)=>s+(e.staff_billing||[]).reduce((ss,sb)=>ss+(sb.incentive||0),0),0);
  const cash = entries.filter(e=>e.branch_id===bid).reduce((s,e)=>s+(e.tips||0)+(e.others||0)+(e.material||0)+(e.petrol||0),0);
  return sal+inc+cash+(b.shop_rent||0)+(b.room_rent||0)+(b.shop_elec||0)+(b.room_elec||0)+(b.wifi||0);
}

