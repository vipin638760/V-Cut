<!-- EXPENSES -->
<div class="page" id="page-expenses">
  <div class="tab2">
    <button class="t2b active" onclick="showExpTab('rent',this)">Rent</button>
    <button class="t2b" onclick="showExpTab('elec',this)">Electricity</button>
    <button class="t2b" onclick="showExpTab('wifi',this)">WiFi</button>
