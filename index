// ── P&L ───────────────────────────────────────────────────────────────────────
function renderPL(){
  const totalInc=branches.reduce((s,b)=>s+bIncome(b.id),0);
  const totalExp=branches.reduce((s,b)=>s+bExpenses(b.id),0);
  document.getElementById('pl-kpis').innerHTML=[
    {l:'Total Income',v:INR(totalInc),c:'green'},{l:'Total Expenses',v:M(totalExp),c:'red'},
    {l:'Net P&L',v:isAdmin?'('+INR(totalExp-totalInc)+')':MASK,c:'red'},
    {l:'Coverage',v:isAdmin&&totalExp>0?(totalInc/totalExp*100).toFixed(1)+'%':MASK,c:'orange'},
  ].map(k=>`<div class="kpi"><div class="kpi-l">${k.l}</div><div class="kpi-v ${k.c}">${k.v}</div></div>`).join('');

  document.getElementById('pl-table').innerHTML=`
    <thead><tr><th>#</th><th>Branch</th><th class="num">Income</th><th class="num">Salary</th><th class="num">Incentives</th><th class="num">Rent</th><th class="num">Elec+WiFi</th><th class="num">Other</th><th class="num">Total Exp</th><th class="num">Net P&L</th></tr></thead>
    <tbody>${branches.map((b,i)=>{
      const inc=bIncome(b.id);
      const sal=bStaff(b.id).reduce((s,st)=>s+(st.salary||0),0);
      const inc2=entries.filter(e=>e.branch_id===b.id).reduce((s,e)=>s+(e.staff_billing||[]).reduce((ss,sb)=>ss+(sb.incentive||0),0),0);
      const rent=(b.shop_rent||0)+(b.room_rent||0);
      const ew=(b.shop_elec||0)+(b.room_elec||0)+(b.wifi||0);
      const misc=entries.filter(e=>e.branch_id===b.id).reduce((s,e)=>s+(e.tips||0)+(e.others||0)+(e.material||0)+(e.petrol||0),0);
      const exp=sal+inc2+rent+ew+misc;const net=inc-exp;
      return `<tr><td style="color:#888">${i+1}</td><td style="font-weight:500;white-space:nowrap">${b.name}</td>
        <td class="num green">${INR(inc)}</td><td class="num">${M(sal)}</td><td class="num">${INR(inc2)}</td><td class="num">${M(rent)}</td><td class="num">${INR(ew)}</td><td class="num">${INR(misc)}</td><td class="num">${M(exp)}</td>
        <td class="num ${net<0?'red':'green'}" style="font-weight:500">${isAdmin?(net<0?'('+INR(net)+')':INR(net)):MASK}</td></tr>`;
    }).join('')}
    <tr class="tf"><td colspan="2">TOTAL</td><td class="num">${INR(totalInc)}</td><td colspan="6"></td><td class="num red">${isAdmin?'('+INR(totalExp-totalInc)+')':MASK}</td></tr></tbody>`;
}

