        <td class="num"><input type="number" value="${b.shop_elec||0}" style="width:90px;text-align:right;padding:5px 7px;border:.5px solid #e0e0e0;border-radius:4px;font-size:12px" ${!isAdmin?'disabled':''} onchange="updateBField('${b.id}','shop_elec',this.value)"></td>
        <td class="num"><input type="number" value="${b.room_elec||0}" style="width:90px;text-align:right;padding:5px 7px;border:.5px solid #e0e0e0;border-radius:4px;font-size:12px" ${!isAdmin?'disabled':''} onchange="updateBField('${b.id}','room_elec',this.value)"></td>
        <td class="num" style="font-weight:500">${INR((b.shop_elec||0)+(b.room_elec||0))}</td></tr>`).join('')}
      <tr class="tf"><td colspan="2">TOTAL</td><td class="num">${INR(branches.reduce((s,b)=>s+(b.shop_elec||0),0))}</td><td class="num">${INR(branches.reduce((s,b)=>s+(b.room_elec||0),0))}</td><td class="num">${INR(branches.reduce((s,b)=>s+(b.shop_elec||0)+(b.room_elec||0),0))}</td></tr></tbody></table>
      <div style="padding:9px 14px;font-size:11px;color:#666">${isAdmin?'Edit values directly — auto-saves to Firebase':'Admin login required to edit'}</div></div>`;
